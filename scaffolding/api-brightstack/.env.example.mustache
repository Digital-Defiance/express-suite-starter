# BrightStack Environment Configuration
# Block store path for persistent storage (leave empty for in-memory)
BRIGHTCHAIN_BLOCKSTORE_PATH={{blockStorePath}}
# Comma-separated block sizes in bytes
BRIGHTCHAIN_BLOCKSIZE_BYTES=1048576
# Block store type: disk, azure-blob, s3
BRIGHTCHAIN_BLOCKSTORE_TYPE=disk
# Set to true for in-memory document store (development)
USE_MEMORY_DOCSTORE={{useMemoryDocstore}}
# Dev database pool name (set for in-memory dev mode, supercedes disk storage)
DEV_DATABASE={{devDatabase}}
# Member pool name
MEMBER_POOL_NAME=BrightChain
# SES credentials for email sending
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
# 64 character hex string
JWT_SECRET={{jwtSecret}}
# Dist directories
API_DIST_DIR=/workspaces/{{workspaceName}}/dist/{{prefix}}-api
REACT_DIST_DIR=/workspaces/{{workspaceName}}/dist/{{prefix}}-react
DEBUG=true
DETAILED_DEBUG=true
EMAIL_DOMAIN=example.com
# Admin and test credentials
ADMIN_ID=""
ADMIN_MNEMONIC=""
ADMIN_ROLE_ID=""
ADMIN_USER_ROLE_ID=""
ADMIN_PASSWORD=""
MEMBER_ID=""
MEMBER_MNEMONIC=""
MEMBER_ROLE_ID=""
MEMBER_PASSWORD=""
MEMBER_USER_ROLE_ID=""
SYSTEM_ID=""
SYSTEM_MNEMONIC=""
SYSTEM_PUBLIC_KEY=""
SYSTEM_ROLE_ID=""
SYSTEM_PASSWORD=""
SYSTEM_USER_ROLE_ID=""
# 64 character hex string
MNEMONIC_ENCRYPTION_KEY={{mnemonicEncryptionKey}}
# 64 character hex string
MNEMONIC_HMAC_SECRET={{mnemonicHmacSecret}}
HTTPS_DEV_CERT_DIR=/workspaces/{{workspaceName}}
HTTPS_DEV_PORT=3443
